MONGODB_URI=mongodb://127.0.0.1:27017/ap-automation
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Email (Module 6)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
APP_URL=http://localhost:3000

# Hybrid OCR - Gemini (free tier: aistudio.google.com)
GEMINI_API_KEY=
# Prefer flash-lite on free tier (2.0-flash often has limit:0 on new keys)
GEMINI_MODEL=gemini-2.0-flash-lite
OCR_CONFIDENCE_THRESHOLD=85
